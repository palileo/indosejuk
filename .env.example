# Frontend static Indo Sejuk AC tidak membaca secret dari file ini.
# File ini hanya contoh untuk backend/serverless/local tooling yang aman.

# Supabase Edge Function / server-side
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_SIDE_SERVICE_ROLE_ONLY

# GitHub snapshot sync server-side
GITHUB_TOKEN=ghp_your_server_side_token
GITHUB_OWNER=your-github-org-or-user
GITHUB_REPO=indosejuk
GITHUB_BRANCH=main
GITHUB_SNAPSHOT_PATH=data/profiles-snapshot.json
GITHUB_UPLOADS_SNAPSHOT_PATH=data/uploads-snapshot.json

# Supabase Storage bucket names
PUBLIC_UPLOAD_BUCKET=app-public-uploads
PRIVATE_DOCUMENT_BUCKET=app-private-documents

# Opsional: endpoint aman untuk workflow/script menarik snapshot
SNAPSHOT_PULL_URL=https://your-secure-backend.example.com/profiles-snapshot
SNAPSHOT_PULL_BEARER=your-server-side-bearer-token

# Opsional untuk scripts/pull-supabase-snapshot.*
INDOSEJUK_SNAPSHOT_URL=https://your-secure-backend.example.com/profiles-snapshot
INDOSEJUK_SNAPSHOT_BEARER=your-server-side-bearer-token
